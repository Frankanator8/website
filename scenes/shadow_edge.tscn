[sub_resource type="Shader" id="Shader_mvpac"]
code = "shader_type canvas_item;
render_mode blend_mix;

// Fades alpha out near the polygon outline.
// Points are the Polygon2D's local-space vertices, pushed by edge_fade_polygon.gd.
const int MAX_POINTS = 64;

uniform vec2 points[MAX_POINTS];
uniform int point_count = 0;
uniform float fade_width : hint_range(0.0, 512.0) = 16.0;
uniform float fade_curve : hint_range(0.1, 8.0) = 1.0;

varying vec2 local_pos;

void vertex() {
	local_pos = VERTEX;
}

// Shortest distance from p to the polygon outline.
float dist_to_edges(vec2 p) {
	float d = 1e20;
	for (int i = 0; i < MAX_POINTS; i++) {
		if (i >= point_count) {
			break;
		}
		int j = i + 1;
		if (j >= point_count) {
			j = 0;
		}
		vec2 a = points[i];
		vec2 b = points[j];
		vec2 ab = b - a;
		vec2 ap = p - a;
		float t = clamp(dot(ap, ab) / max(dot(ab, ab), 0.0001), 0.0, 1.0);
		d = min(d, length(ap - ab * t));
	}
	return d;
}

void fragment() {
	if (point_count >= 3 && fade_width > 0.0) {
		float d = dist_to_edges(local_pos);
		float a = clamp(d / fade_width, 0.0, 1.0);
		COLOR.a *= pow(a, fade_curve);
	}
}
"

