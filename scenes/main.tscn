[node name="ADI" parent="Columbia Info Areas" unique_id=1997803310 instance=ExtResource("6_tefeu")]
position = Vector2(409, -99)
info_text = "ADI (Application Development Initiative) is Columbia's largest CS club on campus! I'm a part of the Education Committee, which means I help plan initiatives like CodeCollab and Mentorship for over 70 participants each. I've met so many talented participants as well as coworkers here."
info_name = "ADI Edu Committee"

