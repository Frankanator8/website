[node name="ADI" parent="Columbia Info Areas" unique_id=1997803310 instance=ExtResource("6_tefeu")]
position = Vector2(409, -99)
info_text = "ADI (Application Development Initiative) is Columbia's largest CS club on campus! I'm a part of the Education Committee, which means I help plan initiatives like CodeCollab and Mentorship for over 70 participants each. I've met so many talented participants as well as coworkers here."
info_name = "ADI Edu Committee"

[node name="CollisionShape2D" parent="Columbia Info Areas/ADI" index="0" unique_id=1083559723]
position = Vector2(0, -1)
shape = SubResource("RectangleShape2D_jkv2x")

[node name="TA" parent="Columbia Info Areas" unique_id=1889179071 instance=ExtResource("6_tefeu")]
position = Vector2(569, -99)
info_text = "I've been an SSL (Summer Student Leader) for the summer program SHAPE. Over 6 weeks, I taught my own class as well as ChemE and Data Structures to high school, and have refined my own approach on creating engaging yet educational experiences."
info_name = "Teaching"

[node name="CollisionShape2D" parent="Columbia Info Areas/TA" index="0" unique_id=1083559723]
shape = SubResource("RectangleShape2D_jbj1t")

[node name="Lab" parent="Columbia Info Areas" unique_id=902380975 instance=ExtResource("6_tefeu")]
position = Vector2(489, -100)
info_text = "I am a Research Assistant at CEAL (Computer-Enabled Abilities Lab), an HCI lab on campus. I was a Summer@SEAS Fellow in 2026, receiving a stipend to do research in helping blind/low vision people enjoy art via audiohaptic feedback and creating a game to learn various programming concepts."
info_name = "CEAL Lab"

[node name="CollisionShape2D" parent="Columbia Info Areas/Lab" index="0" unique_id=1083559723]
shape = SubResource("RectangleShape2D_muem4")

[node name="WE" parent="Columbia Info Areas" unique_id=270574156 instance=ExtResource("6_tefeu")]
position = Vector2(409, -180)
info_text = "I am a first clarinet in CUWE (Columbia Uni Wind Ensemble) as well as its Webmaster/Board member. I love playing my clarinet and this club provides me a way to continue making music. Plus, the people I met here are great :)"
info_name = "Wind Ensemble"

