[node name="Lab" parent="Columbia Info Areas" unique_id=902380975 instance=ExtResource("6_tefeu")]
position = Vector2(489, -100)
info_text = "I am a Research Assistant at CEAL (Computer-Enabled Abilities Lab), an HCI lab on campus. I was a Summer@SEAS Fellow in 2026, receiving a stipend to do research in helping blind/low vision people enjoy art via audiohaptic feedback and creating a game to learn various programming concepts."
info_name = "CEAL Lab"

