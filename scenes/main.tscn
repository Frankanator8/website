[node name="Fall25_special" parent="Floating Books" unique_id=1085379062 instance=ExtResource("18_book")]
position = Vector2(282, -4)
info_text = "Accelerated Physics- honestly been the hardest course I've ever taken. I rethought my studying strategy and grew as an academic, and I bonded with my comrades from doing the homeworks and studying together.
Data Structures in Java - the classic CS course. Here I met Professor Borowski, someone I look up to as a professor and have gotten to know through Office Hours a lot."
info_name = "Fall 25 Highlights"

[node name="Fall25" parent="Floating Books" unique_id=1206571187 instance=ExtResource("18_book")]
position = Vector2(306, 11)
info_text = "GPA: 4.186 (Dean's List) | Credits: 19.5
Multivariable Calculus - A+ (4 credits)
General Chem I - A+ (4 credits)
Data Structures in Java - A+ (3 credits)
Art of Engineering - A (4 credits)
Accelerated Physics (Mechanics) - A (4.5 credits)"
info_name = "Fall 2025"

[node name="Spring26_special" parent="Floating Books" unique_id=685159395 instance=ExtResource("18_book")]
position = Vector2(330, -4)
info_text = "Probability for Engineers - I did extremely well in this class, getting the highest score in the class.
Columbia Build Lab - I worked as a Backup Algorithmic Engineer intern, optimizing many algorithms and working closely with Klee to create faster and stable architecture. I also dipped my toes into real collaborative teamwork, and got to know Docker."
info_name = "Spr. 26 Highlights"

